                let fc = text.substring(fi, fi+4000).replace(/[\r\n]+/g,' ');
                if (data.sid==='N/A') { const m=fc.match(/-(?:N|K|M)\d{4}(?:F|S|M)\d{3,4}\s+([A-Z0-9]{2,7})\b/); if(m&&m[1]!=='DCT') data.sid=m[1]; }
                if (data.star==='N/A') { const r=new RegExp(`([A-Z0-9]{2,7})\\s+-${data.arrIcao}`); const m=fc.match(r); if(m&&m[1]!=='DCT') data.star=m[1]; }
