                    data.validityWindows[curApt].push({start:sS,end:eS,startMins:sMins,endMins:eMins});
                }
            });
        }

        let wxStartIdx = text.indexOf('DESTINATION AIRPORT:');
        if (wxStartIdx !== -1) {
            let wxEnd = text.length;
            for (let m of ['AIRPORTLIST ENDED','N O T A M','NOTAM','WIND SUMMARY','ATC FLIGHT PLAN','FLIGHT LOG']) { let i=text.indexOf(m,wxStartIdx+20); if(i!==-1&&i<wxEnd) wxEnd=i; }
            let wxChunk = text.substring(wxStartIdx, wxEnd); const rawWx=[]; const wxLines=wxChunk.split('\n'); let curIcao=null,curName='',curWxLines=[],isCollecting=false;
            wxLines.forEach(line => {
                let l=line.trim(); if(!l) return; let uL=l.toUpperCase(); let cL=uL.replace(/\s+/g,'');
                if(cL.includes('REG:')||cL.includes('OFP:')||cL.includes('PAGE')) return;
                if(data.flightNo!=='N/A'&&cL.includes(data.flightNo.toUpperCase())) return;
                if(data.reg!=='N/A'&&cL.includes(data.reg.toUpperCase().replace('-',''))) return;
                if(cL.includes('DESTINATIONAIRPORT')||cL.includes('DESTINATIONALTERNATE')||cL.includes('ENROUTEAIRPORT')||cL.includes('ETOPSAIRPORT')||cL.includes('DEPARTUREAIRPORT')){isCollecting=false;return;}
                const tM=l.match(/^([A-Z]{4})\/([A-Z]{3})\s+(.*)/);
                if(tM){if(curIcao&&curWxLines.length>0)rawWx.push({icao:curIcao,name:curName.trim(),raw:curWxLines.join('\n').trim()});curIcao=tM[1];curName=tM[3].trim();curWxLines=[];isCollecting=false;}
                else if(curIcao){if(/\d/.test(l)||/^(?:FT|SA|FC|METAR|TAF|SPECI|TEMPO|BECMG|PROB|FM)/.test(l)){isCollecting=true;curWxLines.push(l);}else{if(!isCollecting){if(curName.length<50)curName+=' '+l;}else{curWxLines.push(l);}}}
