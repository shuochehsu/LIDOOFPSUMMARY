                out.push(`  STD  ${ofpData.stdZ}  (LCL ${ofpData.stdL})`);
                out.push(`  STA  ${ofpData.staZ}  (LCL ${ofpData.staL})`);
                out.push(`  飛行時間: ${ofpData.flightTime}   航段時間: ${ofpData.blockTime}`);
