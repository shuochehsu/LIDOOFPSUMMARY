    // ==========================================
    // 🌬️ 側風 / 飛行類別計算工具函數
    // ==========================================
    /**
     * 從跑道號碼取得磁航向
     * RWY 24 => 240°, RWY 06L => 060°
     */
    const rwyToHeading = (rwyStr) => {
        if (!rwyStr || rwyStr === 'N/A') return null;
        const num = parseInt(rwyStr.replace(/[LRC]/i, ''), 10);
        if (isNaN(num)) return null;
        return (num * 10) % 360;
    };

    /**
     * 計算側風與順逆風分量
     * windDir: 風來的方向 (磁北方向)
     * windSpd: 風速 KT
     * rwyHdg:  跑道磁航向
     */
    const calcCrosswind = (windDir, windSpd, rwyHdg) => {
        if (windDir === null || windSpd === null || rwyHdg === null) return null;
        const angle = (windDir - rwyHdg) * Math.PI / 180;
        const xwind = Math.abs(Math.round(windSpd * Math.sin(angle)));
        const hwind = Math.round(windSpd * Math.cos(angle)); // + = headwind, - = tailwind
        return { xwind, hwind };
    };

    /**
     * 解析 METAR 中的風
     * 回傳 { dir, spd, gust, isVRB }
     * 例: "27015G25KT" => { dir:270, spd:15, gust:25, isVRB:false }
     */
    const parseMetarWind = (metarText) => {
        if (!metarText) return null;
        // 取第一行（METAR 主體行）
        const lines = metarText.split('\n');
        let metarLine = '';
        for (let l of lines) {
            if (/^(METAR|SPECI|SA|SP)\s/i.test(l.trim()) || /^[A-Z]{4}\s+\d{6}Z\s/i.test(l.trim())) {
                metarLine = l; break;
            }
        }
        if (!metarLine) metarLine = lines[0] || '';

        const windReg = /\b(VRB|\d{3})(\d{2,3})(?:G(\d{2,3}))?KT\b/i;
        const m = metarLine.match(windReg);
        if (!m) return null;
        const isVRB = m[1].toUpperCase() === 'VRB';
        return {
            dir: isVRB ? null : parseInt(m[1], 10),
            spd: parseInt(m[2], 10),
            gust: m[3] ? parseInt(m[3], 10) : null,
            isVRB
        };
    };

    /**
     * 判斷飛行類別 (VFR / MVFR / IFR / LIFR)
     * 依據能見度 (SM 或 meters) 和雲幕高 (ft)
     */
    const getFlightCategory = (metarText) => {
        if (!metarText) return null;
        const lines = metarText.split('\n');
        let metarLine = '';
        for (let l of lines) {
            if (/^(METAR|SPECI|SA|SP)\s/i.test(l.trim()) || /^[A-Z]{4}\s+\d{6}Z\s/i.test(l.trim())) {
                metarLine = l; break;
            }
        }
        if (!metarLine) metarLine = lines.find(l => /\d{3}\/\d{2}/.test(l) || /\bKT\b/.test(l)) || lines[0] || '';

        // 能見度 (SM)
        let visSM = null;
        const visSmMatch = metarLine.match(/\b(\d+)(?:\s+(\d+)\/(\d+))?\s*SM\b/);
        const visSmFrac = metarLine.match(/\b(\d+)\/(\d+)\s*SM\b/);
        if (visSmMatch) {
            visSM = parseInt(visSmMatch[1]);
            if (visSmMatch[2]) visSM += parseInt(visSmMatch[2]) / parseInt(visSmMatch[3]);
        } else if (visSmFrac) {
            visSM = parseInt(visSmFrac[1]) / parseInt(visSmFrac[2]);
        }

        // 能見度 (meters / ICAO格式: 9999 or 1500)
        let visM = null;
        const visMMatch = metarLine.match(/\b(\d{4})\b/);
        if (visMMatch && !visSmMatch) {
            const v = parseInt(visMMatch[1]);
            if (v >= 100 && v <= 9999) visM = v;
        }

        // 雲幕高 (最低 BKN/OVC 層)
        let ceilingFt = 99999;
        const cloudReg = /\b(BKN|OVC)(\d{3})\b/gi;
        let cm;
        while ((cm = cloudReg.exec(metarLine)) !== null) {
            const ft = parseInt(cm[2]) * 100;
            if (ft < ceilingFt) ceilingFt = ft;
        }

        // CAVOK / SKC / CLR / NSC = ceiling unlimited
        if (/\b(CAVOK|SKC|CLR|NSC)\b/.test(metarLine)) ceilingFt = 99999;

        // 決定類別
        // LIFR: ceiling < 500ft OR vis < 1SM (or vis < 1600m)
        // IFR:  ceiling 500-999ft OR vis 1-3SM (or 1600-4800m)
        // MVFR: ceiling 1000-3000ft OR vis 3-5SM
        // VFR:  ceiling > 3000ft AND vis > 5SM
        const effVisSM = visSM !== null ? visSM : (visM !== null ? visM / 1609.34 : 99);

        if (ceilingFt < 500 || effVisSM < 1) return 'LIFR';
        if (ceilingFt < 1000 || effVisSM < 3) return 'IFR';
        if (ceilingFt < 3000 || effVisSM < 5) return 'MVFR';
        return 'VFR';
    };

