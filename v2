                        <div className="absolute top-0 left-0 w-1.5 h-full bg-orange-400"></div>
                        <div className={`flex items-center gap-2 ${textSec} mb-3 pb-3 border-b ${dm?'border-[#30363d]':'border-slate-100'}`}><Weight className="w-5 h-5 text-orange-500"/> <h3 className={`text-base font-bold ${textPrim}`}>重量 (Weights)</h3></div>
                        <div className={`grid grid-cols-3 gap-2 text-center text-xs font-bold ${textSec} mb-3`}><div className="text-left">TYPE</div><div>LIMIT</div><div>PLANNED</div></div>
                        <div className="space-y-3">
                            {[['ZFW',data.zfwLimit,data.zfwPlanned],['LDW',data.ldwLimit,data.ldwPlanned],['TOW',data.towLimit,data.towPlanned]].map(([k,lim,plan],i) => (
                                <div key={k} className={`grid grid-cols-3 items-center gap-2 ${i<2?`border-b ${dm?'border-[#30363d]':'border-slate-50'} pb-2`:''}`}>
                                    <span className={`text-sm font-bold ${textPrim}`}>{k}</span>
                                    <span className={`text-center font-mono text-sm font-bold ${textSec}`}>{lim}</span>
                                    <span className={`text-center font-mono text-base font-black ${textPrim} ${dm?'bg-orange-900/30 border-orange-800':'bg-orange-50 border-orange-100'} border rounded py-1`}>{plan}</span>
                                </div>
                            ))}
                        </div>
                    </div>
                    {/* 效能卡 */}
                    <div className={`${cardBase} border p-5 rounded-2xl shadow-sm relative overflow-hidden`}>
                        <div className="absolute top-0 left-0 w-1.5 h-full bg-emerald-500"></div>
                        <div className={`flex items-center gap-2 ${textSec} mb-4 pb-3 border-b ${dm?'border-[#30363d]':'border-slate-100'}`}><Fuel className="w-5 h-5 text-emerald-500"/> <h3 className={`text-base font-bold ${textPrim}`}>效能 (Perf)</h3></div>
                        <div className="space-y-4">
                            <div className="grid grid-cols-2 gap-3">
                                <div className={`flex flex-col ${dm?'bg-emerald-900/30 border-emerald-800':'bg-emerald-50 border-emerald-100'} border p-3 rounded-xl`}><span className={`text-xs font-bold ${dm?'text-emerald-400':'text-emerald-800'} mb-1`}>Total Fuel</span><span className={`font-black text-2xl ${dm?'text-emerald-300':'text-emerald-900'} leading-none`}>{data.totalFuel}</span></div>
                                <div className={`flex flex-col ${dm?'bg-teal-900/30 border-teal-800':'bg-teal-50 border-teal-100'} border p-3 rounded-xl`}><span className={`text-xs font-bold ${dm?'text-teal-400':'text-teal-800'} mb-1`}>ALTN+FIN RES</span><span className={`font-black text-2xl ${dm?'text-teal-300':'text-teal-900'} leading-none`}>{data.reserveFuelSum}</span></div>
                            </div>
                            <div className="flex gap-3">
                                <div className={`${innerSub} border p-3 rounded-xl w-1/3`}><span className={`block text-xs font-bold ${textSec} mb-1`}>CI</span><span className={`font-black text-xl ${textPrim}`}>{data.ci}</span></div>
                                <div className={`${dm?'bg-blue-900/30 border-blue-800':'bg-blue-50 border-blue-100'} border p-3 rounded-xl w-2/3 flex flex-col justify-center overflow-hidden`}><span className={`block text-xs font-bold ${dm?'text-blue-400':'text-blue-500'} mb-1`}>Flight Level</span><span className={`font-black text-xl ${dm?'text-blue-300':'text-blue-700'} tracking-tight`}>{data.fl}</span></div>
                            </div>
                        </div>
                    </div>
                </div>

                {/* DEP / ARR 卡 */}
                <div className={`${cardBase} border p-4 rounded-2xl shadow-sm flex flex-col md:flex-row items-center justify-between gap-4`}>
                    <div className={`flex-1 w-full ${innerBl} border p-4 rounded-xl`}>
                        <div className="flex items-center justify-between mb-3"><div className="flex items-center gap-2"><PlaneTakeoff className="w-6 h-6 text-blue-500"/> <span className={`font-black text-xl ${textPrim}`}>DEP</span></div><span className={`${dm?'bg-blue-800 text-blue-200 border-blue-700':'bg-blue-200 text-blue-900 border-blue-300'} font-black text-base px-3 py-1 rounded-lg border`}>{data.depIcao}</span></div>
                        <div className="flex gap-6"><div><span className={`block text-xs font-bold ${textSec} mb-1`}>RWY</span><span className={`font-black text-2xl ${textPrim} leading-none`}>{data.tkofRwy}</span></div><div><span className={`block text-xs font-bold ${textSec} mb-1`}>SID</span><span className={`font-black text-2xl text-blue-${dm?'400':'700'} leading-none`}>{data.sid}</span></div></div>
                    </div>
                    <ChevronRight className={`w-8 h-8 ${textSec} hidden md:block`} />
                    <div className={`flex-1 w-full ${innerGr} border p-4 rounded-xl`}>
                        <div className="flex items-center justify-between mb-3"><div className="flex items-center gap-2"><PlaneLanding className="w-6 h-6 text-emerald-500"/> <span className={`font-black text-xl ${textPrim}`}>ARR</span></div><span className={`${dm?'bg-emerald-800 text-emerald-200 border-emerald-700':'bg-emerald-200 text-emerald-900 border-emerald-300'} font-black text-base px-3 py-1 rounded-lg border`}>{data.arrIcao}</span></div>
                        <div className="flex gap-6"><div><span className={`block text-xs font-bold ${textSec} mb-1`}>RWY</span><span className={`font-black text-2xl ${textPrim} leading-none`}>{data.ldgRwy}</span></div><div><span className={`block text-xs font-bold ${textSec} mb-1`}>STAR</span><span className={`font-black text-2xl text-emerald-${dm?'400':'700'} leading-none`}>{data.star}</span></div></div>
                    </div>
                </div>

                {/* 天氣區塊 */}
                <div className={`${cardBase} border p-5 rounded-2xl shadow-sm`}>
                    <div className={`flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-4 pb-4 border-b ${dm?'border-[#30363d]':'border-slate-100'}`}>
                        <div className={`flex items-center gap-2 ${textPrim}`}><Wind className="w-6 h-6 text-cyan-500"/> <h2 className="font-black text-xl">天氣預報</h2></div>
                        <div className={`${innerSub} border p-1 rounded-xl flex items-center gap-1 shadow-inner`}>
                            <button onClick={() => handleToggleLiveWx(false)} className={`px-4 py-2 rounded-lg text-sm font-black transition-all ${!useLiveWx ? (dm?'bg-[#21262d] text-[#e6edf3] shadow-md border border-[#30363d]':'bg-white text-slate-700 shadow-md border border-slate-200') : `${textSec} hover:text-slate-600`}`}>📜 OFP 原本</button>
                            <button onClick={() => handleToggleLiveWx(true)}  className={`px-4 py-2 rounded-lg text-sm font-black transition-all flex items-center gap-1.5 ${useLiveWx  ? 'bg-blue-500 text-white shadow-md border border-blue-600' : `${textSec}`}`}>{isFetchingWx?<Clock className="w-4 h-4 animate-spin"/>:<CloudLightning className="w-4 h-4"/>} ⚡ 即時 Live 更新</button>
                        </div>
                    </div>
                    <div className="grid grid-cols-1 lg:grid-cols-2 gap-4">
                        {data.weather.map((wx, idx) => {
                            const windows = data.validityWindows[wx.icao] || [];
                            const isDep=wx.icao===data.depIcao, isArr=wx.icao===data.arrIcao, isAltn=wx.icao===data.altnIcao, isEdto=windows.length>0;
                            let targetMins=null,targetType='',targetTimeZ='';
                            if(isDep){targetMins=data.stdMins;targetType='DEP';targetTimeZ=data.stdZ;}
                            else if(isArr){targetMins=data.staMins;targetType='ARR';targetTimeZ=data.staZ;}
                            else if(isAltn){targetMins=data.altnEtaMins;targetType='ALTN';targetTimeZ=data.altnEtaZ;}
                            else if(isEdto){targetMins=windows[0].startMins;targetType='EDTO';}
                            let badges = [];
                            if(isDep) badges.push({text:`DEP${isEdto?'+EDTO':''}`,bg:isEdto?'bg-fuchsia-600':'bg-blue-600'});
                            else if(isArr) badges.push({text:`ARR${isEdto?'+EDTO':''}`,bg:isEdto?'bg-fuchsia-600':'bg-emerald-600'});
                            else if(isAltn) badges.push({text:`ALTN${isEdto?'+EDTO':''}`,bg:isEdto?'bg-fuchsia-600':'bg-amber-500'});
                            else if(isEdto) badges.push({text:'EDTO',bg:'bg-indigo-500'});

                            const displayRaw = useLiveWx ? (liveWxData[wx.icao] || (isFetchingWx ? '正在連線抓取中...' : '無資料')) : wx.raw;

                            // ★ 側風 & 飛行類別計算 ★
                            const wxForCalc = useLiveWx ? (liveWxData[wx.icao] || wx.raw) : wx.raw;
                            const windInfo = parseMetarWind(wxForCalc);
                            let xwInfo = null;
                            if (windInfo && !windInfo.isVRB) {
                                const rwyForThis = isDep ? data.tkofRwy : isArr ? data.ldgRwy : null;
                                const hdg = rwyToHeading(rwyForThis);
                                if (hdg !== null) xwInfo = calcCrosswind(windInfo.dir, windInfo.spd, hdg);
                            }
                            const fc = getFlightCategory(wxForCalc);
                            const fcCfg = fc ? FC_CONFIG[fc] : null;

                            let xwClass = '';
                            if (xwInfo) {
                                if (xwInfo.xwind >= 20) xwClass = 'xwind-crit';
                                else if (xwInfo.xwind >= 15) xwClass = 'xwind-warn';
                                else xwClass = 'xwind-ok';
                            }

                            return (
                                <div key={idx} className={`${dm?'bg-[#0d1117] border-[#30363d]':'bg-slate-50 border-slate-200'} rounded-xl border overflow-hidden shadow-sm flex flex-col transition-colors ${useLiveWx?(dm?'border-blue-700':'border-blue-300'):''}`}>
                                    <div className={`px-4 py-3 flex flex-row justify-between items-center border-b gap-3 ${useLiveWx?(dm?'bg-blue-900/30 border-blue-800':'bg-blue-50 border-blue-200'):(dm?'bg-[#161b22] border-[#30363d]':'bg-slate-100 border-slate-200')}`}>
                                        <div className="flex-1 min-w-0">
                                            <h4 className={`font-black text-lg ${textPrim} flex items-center gap-2`}>
                                                {wx.icao}
                                                {badges.map((b,i) => <span key={i} className={`text-xs ${b.bg} text-white px-1.5 py-0.5 rounded shadow-sm`}>{b.text}</span>)}
                                                {/* 飛行類別徽章 */}
                                                {fcCfg && <span className={`text-xs px-2 py-0.5 rounded-full font-black ${fcCfg.cls}`}>{fcCfg.emoji} {fcCfg.label}</span>}
                                            </h4>
                                            <span className={`text-xs font-bold ${textSec} block truncate`} title={wx.name}>{wx.name}</span>
                                            {/* 側風資訊列 */}
                                            {xwInfo && (isDep || isArr) && (
                                                <div className="flex flex-wrap items-center gap-2 mt-1.5">
                                                    <span className={`inline-flex items-center gap-1 text-xs font-black px-2 py-0.5 rounded-full ${xwClass}`}>
                                                        <Wind className="w-3 h-3"/>
                                                        側風 {xwInfo.xwind}KT
                                                        {xwInfo.xwind >= 20 && ' ⚠'}
                                                        {xwInfo.xwind >= 15 && xwInfo.xwind < 20 && ' ⚡'}
                                                    </span>
                                                    <span className={`inline-flex items-center gap-1 text-xs font-bold px-2 py-0.5 rounded-full ${dm?'bg-[#21262d] text-[#8b949e] border border-[#30363d]':'bg-slate-100 text-slate-600 border border-slate-200'}`}>
                                                        {xwInfo.hwind >= 0 ? `↑ 逆風 ${xwInfo.hwind}KT` : `↓ 順風 ${Math.abs(xwInfo.hwind)}KT`}
                                                    </span>
                                                    {windInfo && <span className={`text-xs ${textSec}`}>(風向 {windInfo.dir}° / {windInfo.spd}KT{windInfo.gust?`G${windInfo.gust}`:''} | RWY {isDep?data.tkofRwy:data.ldgRwy})</span>}
                                                </div>
                                            )}
                                            {windInfo && windInfo.isVRB && (isDep || isArr) && (
                                                <span className={`mt-1.5 inline-flex items-center gap-1 text-xs font-bold px-2 py-0.5 rounded-full ${dm?'bg-yellow-900/30 text-yellow-400 border border-yellow-700':'bg-yellow-50 text-yellow-700 border border-yellow-200'}`}>
                                                    VRB 風向不定，無法計算側風
                                                </span>
                                            )}
                                        </div>
                                        <div className="text-right shrink-0 flex flex-col gap-1 items-end">
                                            {targetType && targetTimeZ !== 'N/A' && targetType !== 'EDTO' && (
                                                <div>
                                                    <span className={`block text-[10px] font-bold ${textSec} uppercase mb-1`}>{targetType==='DEP'?'ETD':'ETA'}</span>
                                                    <span className={`block text-xs font-black px-2 py-1 rounded shadow-sm border ${targetType==='DEP'?(dm?'bg-blue-900/40 text-blue-300 border-blue-700':'bg-blue-100 text-blue-800 border-blue-200'):targetType==='ARR'?(dm?'bg-emerald-900/40 text-emerald-300 border-emerald-700':'bg-emerald-100 text-emerald-800 border-emerald-200'):(dm?'bg-amber-900/40 text-amber-300 border-amber-700':'bg-amber-100 text-amber-800 border-amber-200')}`}>{targetTimeZ}</span>
                                                </div>
                                            )}
                                            {isEdto && (
                                                <div>
                                                    <span className={`block text-[10px] font-bold ${textSec} uppercase mb-1`}>VALID</span>
                                                    <div className="flex flex-col items-end gap-1">
                                                        {windows.map((w,i) => <span key={i} className={`block text-xs font-black px-2 py-1 rounded shadow-sm border ${targetType!=='EDTO'&&targetType?(dm?'bg-fuchsia-900/40 text-fuchsia-300 border-fuchsia-700':'bg-fuchsia-100 text-fuchsia-900 border-fuchsia-200'):(dm?'bg-yellow-900/40 text-yellow-300 border-yellow-700':'bg-yellow-100 text-red-800 border-yellow-200')}`}>{w.start}-{w.end}</span>)}
                                                    </div>
                                                </div>
                                            )}
                                        </div>
                                    </div>
                                    <div className={`p-4 overflow-x-auto text-sm font-mono ${dm?'text-[#8b949e]':'text-slate-700'} leading-relaxed whitespace-pre relative min-h-[100px] ${dm?'bg-[#0d1117]':''}`}>
                                        {useLiveWx && isFetchingWx && !liveWxData[wx.icao]
                                            ? <div className="text-blue-500 font-bold animate-pulse flex items-center gap-2 mt-2 ml-2"><Clock className="w-5 h-5 animate-spin"/> 連線抓取中...</div>
                                            : highlightTAF(displayRaw, windows, targetMins, targetType, data.baseDate)
                                        }
                                    </div>
                                </div>
                            );
                        })}
                    </div>
                </div>
            </div>
        </div>
    );
}

// ==========================================
// 主程式
// ==========================================
function App() {
    const [activeMainTab, setActiveMainTab] = useState('OFP');
    const [sharedRawText, setSharedRawText] = useState(null);
    const [globalLoading, setGlobalLoading] = useState(false);
    const [globalError, setGlobalError] = useState(null);
    const [showTopBtn, setShowTopBtn] = useState(false);
    const [darkMode, setDarkMode] = useState(false);

    // 共享狀態：NOTAM 釘選
    const [selectedNotams, setSelectedNotams] = useState([]);
    // 共享狀態：NOTAM 資料（供匯出用）
    const [depNotams, setDepNotams] = useState([]);
    const [destNotams, setDestNotams] = useState([]);
    // 共享狀態：OFP 資料
    const [ofpData, setOfpData] = useState(null);
    // 共享狀態：側風資料
    const [crosswindData, setCrosswindData] = useState({ xwDep: null, xwArr: null, fcDep: null, fcArr: null });
    // 匯出 modal
    const [showExport, setShowExport] = useState(false);

    // Dark mode: apply/remove class on <html>
    useEffect(() => {
        if (darkMode) document.documentElement.classList.add('dm');
        else document.documentElement.classList.remove('dm');
    }, [darkMode]);

    useEffect(() => { window.scrollTo({ top: 0, behavior: 'instant' }); }, [activeMainTab]);
    useEffect(() => {
        const h = () => setShowTopBtn(window.scrollY > 300);
        window.addEventListener('scroll', h); return () => window.removeEventListener('scroll', h);
    }, []);

    const handleGlobalFileUpload = (event) => {
        const file = event.target.files[0]; if (!file) return;
        setGlobalLoading(true); setGlobalError(null);
        setTimeout(async () => {
            try {
                const pdfjsLib = window.pdfjsLib;
                const ab = await file.arrayBuffer();
                const pdf = await pdfjsLib.getDocument({ data: ab }).promise;
                let fullText = '';
                for (let i = 1; i <= pdf.numPages; i++) {
                    const page = await pdf.getPage(i);
                    const content = await page.getTextContent();
                    let lMap = new Map();
                    content.items.forEach(item => {
                        let y = Math.round(item.transform[5]/4)*4;
                        if (!lMap.has(y)) lMap.set(y, []);
                        lMap.get(y).push(item);
                    });
                    let yKeys = Array.from(lMap.keys()).sort((a,b) => b-a);
                    let pageText = yKeys.map(y => {
                        let li = lMap.get(y); li.sort((a,b) => a.transform[4]-b.transform[4]);
                        let ls = ''; let lx = -1;
                        li.forEach(it => { if(lx!==-1&&(it.transform[4]-lx>10))ls+=' '; ls+=it.str; lx=it.transform[4]+it.width; });
                        return ls.trim();
                    }).join('\n');
                    fullText += pageText + '\n';
                }
                setSharedRawText(fullText);
                setSelectedNotams([]); setDepNotams([]); setDestNotams([]); setOfpData(null);
                setCrosswindData({ xwDep: null, xwArr: null, fcDep: null, fcArr: null });
            } catch(err) {
                console.error("Global PDF Error:", err);
                setGlobalError("讀取 PDF 失敗，請確認是否為有效 LIDO 文件。");
            } finally { setGlobalLoading(false); }
        }, 50);
    };

    const handleReset = () => {
        setSharedRawText(null); setGlobalError(null); setActiveMainTab('OFP');
        setSelectedNotams([]); setDepNotams([]); setDestNotams([]); setOfpData(null);
        setCrosswindData({ xwDep: null, xwArr: null, fcDep: null, fcArr: null });
    };

    const navBg = darkMode ? 'bg-[#010409] border-b border-[#30363d]' : 'bg-slate-900 shadow-lg border-b border-slate-800';
    const pageBg = darkMode ? 'bg-[#0d0f14]' : 'bg-slate-200';

    return (
        <div className={`min-h-screen font-sans flex flex-col ${pageBg}`}>
            {!sharedRawText ? (
                <div className="flex-1 flex flex-col items-center justify-center p-6">
                    <div className={`max-w-xl w-full p-10 rounded-2xl shadow-xl border text-center ${darkMode ? 'bg-[#161b22] border-[#30363d]' : 'bg-white border-slate-200'}`}>
                        <div className="flex justify-center mb-6 gap-4 text-blue-500">
                            <AlertTriangle className="w-12 h-12"/>
                            <FileText className="w-12 h-12 text-emerald-500"/>
                        </div>
                        <h1 className={`text-3xl font-black mb-2 ${darkMode ? 'text-[#e6edf3]' : 'text-slate-800'}`}>LIDO OFP 助理</h1>
                        <p className={`font-medium mb-8 ${darkMode ? 'text-[#8b949e]' : 'text-slate-500'}`}>NOTAM 篩選與 OFP 天氣摘要</p>
                        <label className={`relative cursor-pointer bg-blue-600 text-white px-6 py-5 rounded-xl font-bold hover:bg-blue-700 transition-all flex flex-col items-center justify-center gap-3 w-full shadow-lg shadow-blue-600/20 ${globalLoading ? 'opacity-70 pointer-events-none' : ''}`}>
                            {globalLoading ? (<><Clock className="w-8 h-8 animate-spin"/> <span className="text-lg">系統解析中，請稍候...</span></>) : (<><UploadCloud className="w-10 h-10"/> <span className="text-lg tracking-wide">選擇 LIDO OFP 檔案 (PDF)</span></>)}
                            <input type="file" accept="application/pdf" className="hidden" onChange={handleGlobalFileUpload} disabled={globalLoading}/>
                        </label>
                        {/* 上傳頁的 dark mode 切換 */}
                        <div className="mt-6 flex justify-center">
                            <button onClick={() => setDarkMode(!darkMode)} className={`flex items-center gap-2 px-4 py-2 rounded-full text-sm font-bold transition-all border ${darkMode ? 'bg-[#21262d] border-[#30363d] text-[#c9d1d9] hover:bg-[#30363d]' : 'bg-slate-100 border-slate-200 text-slate-600 hover:bg-slate-200'}`}>
                                {darkMode ? <Sun className="w-4 h-4 text-yellow-400"/> : <Moon className="w-4 h-4 text-slate-500"/>}
                                {darkMode ? '切換日間模式' : '切換夜間模式'}
                            </button>
                        </div>
                        {globalError && (
                            <div className="mt-6 p-4 bg-rose-50 border border-rose-200 rounded-xl text-rose-700 flex items-start gap-3 text-left">
                                <AlertTriangle className="w-5 h-5 flex-shrink-0 mt-0.5"/><p className="font-bold">{globalError}</p>
                            </div>
                        )}
                    </div>
                </div>
            ) : (
                <Fragment>
                    <nav className={`${navBg} sticky top-0 z-50`}>
                        <div className="max-w-6xl mx-auto px-4 py-3 flex flex-wrap justify-between items-center gap-4">
                            <div className="flex gap-2">
                                <button onClick={() => setActiveMainTab('OFP')}   className={`px-5 py-2.5 rounded-full font-bold text-sm transition-all flex items-center gap-2 ${activeMainTab==='OFP'   ? 'bg-emerald-600 text-white shadow-[0_0_15px_rgba(16,185,129,0.5)]' : (darkMode?'bg-[#161b22] text-[#8b949e] hover:bg-[#21262d]':'bg-slate-800 text-slate-400 hover:bg-slate-700 hover:text-slate-200')}`}><FileText className="w-4 h-4"/> OFP 摘要</button>
                                <button onClick={() => setActiveMainTab('NOTAM')} className={`px-5 py-2.5 rounded-full font-bold text-sm transition-all flex items-center gap-2 ${activeMainTab==='NOTAM' ? 'bg-blue-600 text-white shadow-[0_0_15px_rgba(37,99,235,0.5)]'  : (darkMode?'bg-[#161b22] text-[#8b949e] hover:bg-[#21262d]':'bg-slate-800 text-slate-400 hover:bg-slate-700 hover:text-slate-200')}`}><AlertTriangle className="w-4 h-4"/> NOTAM 過濾</button>
                            </div>
                            <div className="flex items-center gap-2">
                                {/* 匯出按鈕 */}
                                <button onClick={() => setShowExport(true)} className="flex items-center gap-2 px-4 py-2 rounded-full text-sm font-bold transition-all bg-emerald-700 hover:bg-emerald-600 text-white border border-emerald-600 shadow-sm">
                                    <Download className="w-4 h-4"/> 匯出精華版
                                </button>
                                {/* 夜間模式切換 */}
                                <button onClick={() => setDarkMode(!darkMode)} title={darkMode?'切換日間模式':'切換夜間模式'} className={`p-2.5 rounded-full transition-all border ${darkMode ? 'bg-yellow-400/20 border-yellow-500/40 text-yellow-300 hover:bg-yellow-400/30' : 'bg-slate-700 border-slate-600 text-slate-300 hover:bg-slate-600'}`}>
                                    {darkMode ? <Sun className="w-4 h-4"/> : <Moon className="w-4 h-4"/>}
                                </button>
                                <button onClick={handleReset} className={`text-sm font-bold transition-colors px-4 py-2 rounded-full border ${darkMode?'text-[#8b949e] hover:text-[#c9d1d9] bg-[#161b22] border-[#30363d]':'text-slate-400 hover:text-white bg-slate-800 border-slate-700'}`}>重新上傳</button>
                            </div>
                        </div>
                    </nav>

                    <div className={`flex-1 ${activeMainTab==='OFP' ? 'block' : 'hidden'}`}>
                        <OfpSummaryApp
                            rawText={sharedRawText}
                            darkMode={darkMode}
                            onOfpDataReady={setOfpData}
                            onCrosswindReady={setCrosswindData}
                        />
                    </div>
                    <div className={`flex-1 ${activeMainTab==='NOTAM' ? 'block' : 'hidden'}`}>
                        <NotamFilterApp
                            rawText={sharedRawText}
                            darkMode={darkMode}
                            selectedNotams={selectedNotams}
                            setSelectedNotams={setSelectedNotams}
                            onNotamsReady={(dep, dest) => { setDepNotams(dep); setDestNotams(dest); }}
