                const am = line.match(/\b([A-Z]{4})\b/); if(am && !line.includes('TO')) curApt=am[1]; if(am && line.includes('VALIDITY WINDOW')) curApt=am[1];
                const tR = /(\d{2}:\d{2}[Zz27]?)\s+(?:TO|T[O0Ο])\s+(\d{2}:\d{2}[Zz27]?)/gi; let tm;
                while ((tm=tR.exec(line))!==null && curApt) {
                    const sS=tm[1].toUpperCase().replace(/[27]$/,'Z'); const eS=tm[2].toUpperCase().replace(/[27]$/,'Z');
                    let cS=sS.replace(/[^0-9]/g,''); let cE=eS.replace(/[^0-9]/g,'');
                    let hS=parseInt(cS.substring(0,2)),mS=parseInt(cS.substring(2,4)),dayS=data.baseDate; if(hS*60+mS<stdMinsRaw-360)dayS+=1; let sMins=dayS*24*60+hS*60+mS;
                    let hE=parseInt(cE.substring(0,2)),mE=parseInt(cE.substring(2,4)),dayE=data.baseDate; if(hE*60+mE<stdMinsRaw-360)dayE+=1; let eMins=dayE*24*60+hE*60+mE;
                    if(eMins<sMins) eMins+=24*60;
