        const fuelMatch = topText.match(/TOTAL[\s\n]*(\d{5,6})/); if (fuelMatch) data.totalFuel = fuelMatch[1];
        const zfwMatch = topText.match(/ZFW\s+(\d+\.\d+)\s*\/\s*(\d+\.\d+)/); if (zfwMatch) { data.zfwLimit = zfwMatch[1]; data.zfwPlanned = zfwMatch[2]; }
        const ldwMatch = topText.match(/LDW\s+(\d+\.\d+)\s*\/\s*(\d+\.\d+)/); if (ldwMatch) { data.ldwLimit = ldwMatch[1]; data.ldwPlanned = ldwMatch[2]; }
        const towMatch = topText.match(/TOW\s+(\d+\.\d+)\s*\/\s*(\d+\.\d+)/); if (towMatch) { data.towLimit = towMatch[1]; data.towPlanned = towMatch[2]; }
        let altnFuel = 0, finalResFuel = 0;
        const altnMatch = topText.match(/ALTN\s+([A-Z]{4})?\s*(\d{3,6})\s+(\d{2})\.(\d{2})/);
        if (altnMatch) { if (altnMatch[1]) data.altnIcao = altnMatch[1]; altnFuel = parseInt(altnMatch[2], 10); let addH = parseInt(altnMatch[3]); let addM = parseInt(altnMatch[4]); if (data.staMins !== null) { data.altnEtaMins = data.staMins + addH*60 + addM; let hE = Math.floor(data.altnEtaMins/60)%24; let mE = data.altnEtaMins%60; data.altnEtaZ = hE.toString().padStart(2,'0') + mE.toString().padStart(2,'0') + 'Z'; } }
        const finalResMatch = topText.match(/FINAL RES[^\d]+(\d{3,6})/); if (finalResMatch) finalResFuel = parseInt(finalResMatch[1]);
        if (altnFuel || finalResFuel) data.reserveFuelSum = (altnFuel + finalResFuel).toString();
        const ciMatch = topText.match(/CRZ\s+CI(\d+)/); if (ciMatch) data.ci = ciMatch[1];

        let fplStart = text.indexOf('(FPL-');
        if (fplStart !== -1) {
            let fplChunk = text.substring(fplStart, fplStart+3000);
            const flMatches = [...fplChunk.matchAll(/(?:-|\/)[NMK]\d{3,4}([FSM])(\d{3,4})/g)];
            if (flMatches.length > 0) {
                const uFLs = []; flMatches.forEach(m => { let t=m[1],v=parseInt(m[2]),s=(t==='F'?'FL':t)+m[2]; if(!uFLs.find(x=>x.str===s)) uFLs.push({type:t,val:v,str:s}); });
                let res = []; ['S','M','F'].forEach(t => { let list=uFLs.filter(x=>x.type===t).map(x=>x.val); if(list.length>0){let init=list[0],max=Math.max(...list),pfx=t==='F'?'FL':t; res.push(init<max?`${pfx}${init} - ${max}`:`${pfx}${init}`);} }); data.fl = res.join(' / ');
            }
        }

        let navLogStart = text.indexOf('NAVIGATION LOG'); if (navLogStart===-1) navLogStart=0;
        if (data.depIcao !== 'N/A') { const dR = new RegExp(data.depIcao+'\\/([0-3]\\d[LRC]?)'); const dM = text.substring(navLogStart).match(dR); if (dM) { data.tkofRwy=dM[1]; let after=text.substring(navLogStart+dM.index, navLogStart+dM.index+1000); let words=after.split(/[\s\n]+/); for(let w of words){if(/^[A-Z]{3,6}\d{1,2}[A-Z]?$/.test(w)){data.sid=w;break;}} } }
        if (data.arrIcao !== 'N/A') { const aR = new RegExp(data.arrIcao+'\\/([0-3]\\d[LRC]?)','g'); const aMs=[...text.substring(navLogStart).matchAll(aR)]; if(aMs.length>0){let last=aMs[aMs.length-1]; data.ldgRwy=last[1]; let before=text.substring(navLogStart+Math.max(0,last.index-1000),navLogStart+last.index); let words=before.split(/[\s\n]+/); for(let i=words.length-1;i>=0;i--){if(/^[A-Z]{3,6}\d{1,2}[A-Z]?$/.test(words[i])){data.star=words[i];break;}}} }
        if (data.sid==='N/A' || data.star==='N/A') {
