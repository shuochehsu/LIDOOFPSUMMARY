                out.push(`  DEP ${ofpData.depIcao}  RWY ${ofpData.tkofRwy}  SID ${ofpData.sid}`);
                out.push(`  ARR ${ofpData.arrIcao}  RWY ${ofpData.ldgRwy}  STAR ${ofpData.star}`);
                out.push('');
            }

            // 側風區塊
            const hasXW = crosswindDep || crosswindDest || flightCatDep || flightCatDest;
            if (hasXW) {
                out.push('【側風 / 天氣類別】');
                if (ofpData && crosswindDep) {
                    const xw = crosswindDep;
                    const hw = xw.hwind >= 0 ? `↑ 逆風 ${xw.hwind}KT` : `↓ 順風 ${Math.abs(xw.hwind)}KT`;
                    out.push(`  DEP ${ofpData.depIcao} RWY${ofpData.tkofRwy}  側風 ${xw.xwind}KT  ${hw}${xw.xwind >= 20 ? '  ⚠ 側風偏大' : xw.xwind >= 15 ? '  ⚡ 注意側風' : ''}`);
                }
                if (ofpData && crosswindDest) {
                    const xw = crosswindDest;
                    const hw = xw.hwind >= 0 ? `↑ 逆風 ${xw.hwind}KT` : `↓ 順風 ${Math.abs(xw.hwind)}KT`;
                    out.push(`  ARR ${ofpData.arrIcao} RWY${ofpData.ldgRwy}  側風 ${xw.xwind}KT  ${hw}${xw.xwind >= 20 ? '  ⚠ 側風偏大' : xw.xwind >= 15 ? '  ⚡ 注意側風' : ''}`);
                }
                if (flightCatDep && ofpData)  out.push(`  DEP ${ofpData.depIcao}  飛行類別: ${flightCatDep}`);
                if (flightCatDest && ofpData) out.push(`  ARR ${ofpData.arrIcao}  飛行類別: ${flightCatDest}`);
                out.push('');
            }

            // 釘選 NOTAM
            const allNotams = [...(depNotams||[]), ...(destNotams||[])];
            const pinned = allNotams.filter(n => selectedNotams.includes(n.id));
            if (pinned.length > 0) {
                out.push('【⭐ 標記的重要 NOTAMs】');
                pinned.forEach(n => {
                    out.push(line(52));
                    out.push(`  ${n.id}`);
                    out.push(n.text.split('\n').map(l => '  ' + l).join('\n'));
                });
                out.push(line(52));
                out.push('');
            }

            out.push(dbl(52));
            out.push(`  Generated by LIDO OFP 助理`);
            out.push(dbl(52));

            return out.join('\n');
        };

        const text = buildText();

        const handleCopy = () => {
            navigator.clipboard.writeText(text).then(() => {
                setCopied(true);
                setTimeout(() => setCopied(false), 2000);
            });
        };

        return (
            <div className="fixed inset-0 z-[9999] flex items-center justify-center p-4 dm-modal-overlay" style={{backgroundColor:'rgba(0,0,0,0.7)'}}>
                <div className="bg-white dm-modal rounded-2xl shadow-2xl w-full max-w-2xl flex flex-col max-h-[90vh] border border-slate-200">
                    <div className="flex items-center justify-between p-5 border-b border-slate-200 dm-border">
                        <h2 className="font-black text-xl text-slate-800 dm-text-primary flex items-center gap-2">
                            <Download className="w-6 h-6 text-emerald-600" />
                            匯出駕駛艙精華版
                        </h2>
                        <button onClick={onClose} className="p-2 rounded-lg hover:bg-slate-100 text-slate-500 transition-colors">
                            <X className="w-5 h-5" />
                        </button>
                    </div>
                    <div className="p-5 flex-1 overflow-hidden flex flex-col gap-3">
                        <p className="text-sm text-slate-500 dm-text-secondary">以下為精華版純文字，可直接複製貼上至記事本或列印成 A4 帶上飛機。</p>
                        <textarea
                            readOnly
                            value={text}
                            className="flex-1 min-h-[340px] font-mono text-xs bg-slate-50 dm-modal-textarea border border-slate-200 rounded-xl p-4 resize-none focus:outline-none leading-relaxed"
                        />
                    </div>
                    <div className="p-5 border-t border-slate-200 dm-border flex gap-3 justify-end">
                        <button onClick={onClose} className="px-5 py-2.5 rounded-xl font-bold text-slate-600 bg-slate-100 hover:bg-slate-200 transition-colors text-sm">
                            關閉
                        </button>
                        <button onClick={handleCopy} className={`px-5 py-2.5 rounded-xl font-bold text-white transition-all text-sm flex items-center gap-2 ${copied ? 'bg-emerald-600' : 'bg-blue-600 hover:bg-blue-700'}`}>
                            <Copy className="w-4 h-4" />
                            {copied ? '✓ 已複製！' : '複製全文'}
                        </button>
                    </div>
                </div>
            </div>
        );
    }

    // ==========================================
    // 模組 1: NOTAM Filter
    // ==========================================
    function NotamFilterApp({ rawText, darkMode, selectedNotams, setSelectedNotams, onNotamsReady }) {
        const [parsedData, setParsedData] = useState(null);
        const [flightInfo, setFlightInfo] = useState(null);
        const [activeTab, setActiveTab] = useState('DEP');
        const [showFiltered, setShowFiltered] = useState(true);
        const [bufferHours, setBufferHours] = useState(1);
        const [localError, setLocalError] = useState(null);

        const [hideObstacles, setHideObstacles] = useState(true);
        const [hideBirds, setHideBirds] = useState(true);
        const [hideUAS, setHideUAS] = useState(true);
        const [hideMowing, setHideMowing] = useState(true);

        const toggleNotamSelection = (id) => {
            setSelectedNotams(prev => prev.includes(id) ? prev.filter(x => x !== id) : [...prev, id]);
        };

        useEffect(() => { window.scrollTo({ top: 0, behavior: 'auto' }); }, [activeTab]);

        useEffect(() => {
            if (!rawText) { setParsedData(null); setFlightInfo(null); setLocalError(null); return; }
            try {
                const cleanText = sanitizeText(rawText);
                processBriefingText(cleanText);
                setLocalError(null);
            } catch (err) {
                console.error("NOTAM parsing error", err);
                setLocalError("無法在文件中找到完整的航班資訊，NOTAM 模組無法啟用。");
            }
        }, [rawText]);

        const sanitizeText = (raw) => {
            let c = raw;
            c = c.replace(/---\s*PAGE\s*\d+\s*---/gi, '\n');
            c = c.replace(/PAGE\s*[\n\r]*\s*\d+\s*[\n\r]*\s*OF\s*[\n\r]*\s*\d+/gi, '\n');
            c = c.replace(/\b\d+\s*[\n\r]*\s*OF\s*[\n\r]*\s*\d+\b/gi, '\n');
            c = c.replace(/\bPAGE\s*[\n\r]*\s*\d+\b/gi, '\n');
            c = c.replace(/BR\s+\d{3}\/\d{2}[A-Za-z]{3}\d{2}\/[A-Z]{3}-[A-Z]{3}.*?OFP:\s*\d+\/\d+\/\d+/gi, '\n');
            c = c.replace(/Reg:\s*[A-Z0-9-]+\s*[\n\r]*\s*OFP:\s*\d+\/\d+\/\d+/gi, '\n');
            c = c.replace(/\+{5,}\s*[A-Z\s]+\s*\+{5,}/gi, '\n');
            return c;
        };

        const parseZTime = (dateStr, timeStr) => {
            const months = { JAN:0, FEB:1, MAR:2, APR:3, MAY:4, JUN:5, JUL:6, AUG:7, SEP:8, OCT:9, NOV:10, DEC:11 };
            const m = dateStr.match(/(\d{2})([A-Z]{3})(\d{2})/i);
            if (!m) return new Date();
            return new Date(Date.UTC(2000+parseInt(m[3]), months[m[2].toUpperCase()], parseInt(m[1]), parseInt(timeStr.substring(0,2)), parseInt(timeStr.substring(2,4))));
        };

        const parseToBlocks = (rawText) => {
            if (!rawText) return [];
            const blocks = rawText.split(/(?=\b[A-Z0-9]+\/\d{2}\s+(?:VALID:|COMPANY\s+NOTAM))/i);
            const parsed = blocks.filter(b => b.trim()).map(block => {
                const idMatch = block.match(/^([A-Z0-9]+\/\d{2})\s+(?:VALID:|COMPANY\s+NOTAM)/i);
                if (!idMatch) return null;
                let text = block.trim();
                const hi = text.search(/BR\s+\d{3}\/\d{2}[A-Za-z]{3}\d{2}/i);
                if (hi !== -1 && hi > 20) text = text.substring(0, hi).trim();
                text = text.replace(/\+{5,}\s*[A-Z\s]+\s*\+{5,}/gi, '').trim();
                text = text.replace(/(\n\s*){2,}/g, '\n');
                return { id: idMatch[1], text };
            }).filter(Boolean);

            const map = new Map();
            parsed.forEach(b => {
                if (map.has(b.id)) { let e = map.get(b.id); if (!e.text.includes(b.text)) e.text += '\n' + b.text; }
                else map.set(b.id, { ...b });
            });
            return Array.from(map.values());
        };

        const processBriefingText = (text) => {
            const routeMatch = text.match(/([A-Z]{4})\/([A-Z]{4})/);
            const dateMatch  = text.match(/(\d{2}[A-Z]{3}\d{2})/i);
            const stdMatch   = text.match(/STD\s+\d{4}L\s+(\d{4})Z/i);
            const staMatch   = text.match(/STA\s+\d{4}L\s+(\d{4})Z/i);
            if (!routeMatch || !dateMatch || !stdMatch || !staMatch) throw new Error("Missing critical flight info");

            const depAirport = routeMatch[1]; const destAirport = routeMatch[2];
            const stdDate = parseZTime(dateMatch[1], stdMatch[1]);
            const staDate = parseZTime(dateMatch[1], staMatch[1]);
            if (staDate < stdDate) staDate.setUTCDate(staDate.getUTCDate() + 1);

            const depSecM  = text.match(/={3,}\s*DEPARTURE AIRPORT\s*={3,}([\s\S]*?)(?=={3,}\s*DESTINATION AIRPORT\s*={3,})/i);
            const destSecM = text.match(/={3,}\s*DESTINATION AIRPORT\s*={3,}([\s\S]*?)(?=={3,}\s*DESTINATION ALTERNATE\(S\)\s*={3,}|={3,}\s*ENROUTE AIRPORT\(S\)\s*={3,})/i);

            setParsedData({
                depAirport, destAirport, std: stdDate, sta: staDate,
                depBlocks:  parseToBlocks(depSecM  ? depSecM[1]  : ''),
                destBlocks: parseToBlocks(destSecM ? destSecM[1] : '')
            });
        };

        const categorizeNotam = (text) => {
            const u = text.toUpperCase();
            const isClsd = /\b(?:CLSD|CLOSED)\b/.test(u);
            if (isClsd) {
                const rwy = u.match(/\b(?:RWY|RUNWAY)\b/);
                const twy = u.match(/\b(?:TWY|TAXIWAY|TXL|RAMP|APRON|PRKG|PARKING|BAY|STAND)\b/);
                if (rwy && twy) return rwy.index < twy.index ? 'RWY_CLSD' : 'TWY_CLSD';
                if (rwy) return 'RWY_CLSD';
                if (twy) return 'TWY_CLSD';
            }
            if (/\bCOMPANY\s+NOTAM\b/.test(u)) return 'COMPANY_NOTAM';
            if (/\b(?:MISSED\s+APPROACH|MISSED\s+APCH|MAPT|MAPC)\b/.test(u)) return 'MISSED_APPROACH';
            if (/\b(?:TAKEOFF\s+MINIMUMS?|TAKEOFF\s+MINIMA|TKOF\s+MINIMUMS?|TKOF\s+MINIMA)\b/.test(u)) return 'TAKEOFF_MINIMUM';
            const isLdgMin = /\b(?:APP\s+MINIMUM|APPROACH\s+MINIMUM|MINIMA|MINIMUMS?|DA\/MDA|OCA\/H|DA\s+\d+|HAT\s+\d+|VISIBILITY\s+RVR|RVR\s+\d+|CAT\s+II|CAT\s+III)\b/.test(u) ||
                             /\b(?:ILS|LOC|RNAV|RNP|VOR|NDB|GLS).*RWY.*\b(?:AMDT|ORIG)\b/.test(u);
            if (isLdgMin) return 'LANDING_MINIMUM';
            if (/\b(?:LGT|LIGHT|LIGHTS|NAV|ILS|VOR|NDB|GP|LOC|DME|PAPI|VASI|ALS|RADAR)\b/.test(u) && /\b(?:U\/S|UNSERVICEABLE|OUT\s+OF\s+SERVICE|OTS)\b/.test(u)) return 'EQUIP_US';
            if (/\b(?:BIRD|BIRDS|WILDLIFE|FOWL|FLOCK|AVIAN)\b/.test(u)) return 'BIRD_HAZARD';
            if (/\b(?:UAS|UNMANNED|DRONE|KITE|BALLOON|FIREWORK|LASER|PARACHUTE|UAV)\b/.test(u)) return 'UAS_KITE';
            if (/\b(?:MOWING|GRASS CUTTING|WEED|SWEEPING|LAWN)\b/.test(u) && !/\b(?:CLSD|CLOSED)\b/.test(u)) return 'MAINTENANCE';
            if (/\b(?:CRANE|CRANES|OBST|OBSTACLE|IRREGULAR\s+SFC|IRREGULAR\s+SURFACE)\b/.test(u)) return 'OBSTACLE_ETC';
            return 'NORMAL';
        };

        useEffect(() => {
            if (!parsedData) return;
            const { depAirport, destAirport, std, sta, depBlocks, destBlocks } = parsedData;

            const processBlocks = (blocks, flightTime) => blocks.map(block => {
                let { keep, reason } = checkNotamRelevance(block.text, flightTime, bufferHours);
                const category = categorizeNotam(block.text);
                if (keep) {
                    if (category === 'OBSTACLE_ETC' && hideObstacles) { keep = false; reason = '依設定自動隱藏 (障礙物/不平整表面)'; }
                    if (category === 'BIRD_HAZARD'  && hideBirds)    { keep = false; reason = '依設定自動隱藏 (鳥類/野生動物警告)'; }
                    if (category === 'UAS_KITE'     && hideUAS)       { keep = false; reason = '依設定自動隱藏 (無人機/氣球/煙火活動)'; }
                    if (category === 'MAINTENANCE'  && hideMowing)    { keep = false; reason = '依設定自動隱藏 (周邊除草/例行維護)'; }
                }
                return { ...block, keep, reason, category };
            });

            const di = processBlocks(depBlocks, std);
            const de = processBlocks(destBlocks, sta);
            setFlightInfo({ depAirport, destAirport, std, sta, depNotams: di, destNotams: de });
            if (onNotamsReady) onNotamsReady(di, de);
        }, [parsedData, bufferHours, hideObstacles, hideBirds, hideUAS, hideMowing]);

        // Notify parent when flight info changes
        useEffect(() => {
            if (flightInfo && onNotamsReady) onNotamsReady(flightInfo.depNotams, flightInfo.destNotams);
        }, [flightInfo]);

        const checkNotamRelevance = (notamText, flightTime, buffer) => {
            const winStart = new Date(flightTime.getTime() - buffer * 3600 * 1000);
            const winEnd   = new Date(flightTime.getTime() + buffer * 3600 * 1000);

            const validMatch = notamText.match(/VALID:\s*(\d{10})\s*(?:-\s*(\d{10}|PERM|UFN|EST))?/i);
            if (validMatch) {
                const p = (s) => new Date(Date.UTC(2000+parseInt(s.slice(0,2)), parseInt(s.slice(2,4))-1, parseInt(s.slice(4,6)), parseInt(s.slice(6,8)), parseInt(s.slice(8,10))));
                const fromDate = p(validMatch[1]);
                let toDate = new Date(Date.UTC(2099, 11, 31));
                if (validMatch[2] && /^\d{10}$/.test(validMatch[2])) toDate = p(validMatch[2]);
                if (winEnd < fromDate) return { keep: false, reason: '在航班起飛前尚未生效' };
                if (winStart > toDate)  return { keep: false, reason: '在航班到達前已失效' };
            }

            const dailyRegex = /\b(\d{4})Z?\s*-\s*(\d{4})Z?\b/ig;
            let dm; const dailyRanges = [];
            while ((dm = dailyRegex.exec(notamText)) !== null) {
                const sm = parseInt(dm[1].slice(0,2))*60 + parseInt(dm[1].slice(2,4));
                const em = parseInt(dm[2].slice(0,2))*60 + parseInt(dm[2].slice(2,4));
                if (sm <= 1440 && em <= 1440) dailyRanges.push({ start: sm, end: em, raw: dm[0] });
            }
            if (dailyRanges.length > 0) {
                let overlaps = false;
                for (let r of dailyRanges) {
                    const rS = new Date(flightTime); rS.setUTCHours(Math.floor(r.start/60), r.start%60, 0, 0);
                    const rE = new Date(flightTime); rE.setUTCHours(Math.floor(r.end/60),   r.end%60,   0, 0);
                    if (rE < rS) {
                        rE.setUTCDate(rE.getUTCDate() + 1);
                        const rSP = new Date(rS); rSP.setUTCDate(rSP.getUTCDate() - 1);
                        const rEP = new Date(rE); rEP.setUTCDate(rEP.getUTCDate() - 1);
                        if ((winStart <= rEP && winEnd >= rSP) || (winStart <= rE && winEnd >= rS)) { overlaps = true; break; }
                    } else {
                        if (winStart <= rE && winEnd >= rS) { overlaps = true; break; }
                    }
                }
                if (!overlaps) return { keep: false, reason: `每日時間區間不重疊 (${dailyRanges.map(r=>r.raw).join(', ')})` };
            }
            return { keep: true, reason: '符合航班時間' };
        };

        const formatZTime = (date) =>
            `${date.getUTCDate().toString().padStart(2,'0')}${date.toLocaleString('en-US',{month:'short',timeZone:'UTC'}).toUpperCase()}${date.getUTCFullYear().toString().slice(-2)} ${date.getUTCHours().toString().padStart(2,'0')}${date.getUTCMinutes().toString().padStart(2,'0')}Z`;

        const cardBase  = darkMode ? 'bg-[#161b22] border-[#30363d]' : 'bg-white border-slate-200';
        const tabBg     = darkMode ? 'bg-[#0d1117]' : 'bg-slate-50';
        const textPrim  = darkMode ? 'text-[#e6edf3]' : 'text-slate-800';
        const textSec   = darkMode ? 'text-[#8b949e]' : 'text-slate-500';
        const selectCls = darkMode ? 'bg-[#21262d] border-[#30363d] text-[#c9d1d9]' : 'bg-white border-slate-300 text-slate-700';
        const innerCard = darkMode ? 'bg-[#0d1117] border-[#30363d]' : 'bg-slate-50 border-slate-200';

        const FilterControls = () => (
            <div className="flex flex-col gap-3 w-full xl:w-auto mt-4 xl:mt-0 pt-4 xl:pt-0 border-t xl:border-t-0 border-slate-100">
                <div className="flex flex-wrap items-center justify-end gap-2">
                    <div className={`flex items-center gap-2 ${innerCard} border py-1.5 px-3 rounded-lg shadow-sm`}>
                        <Clock className="w-4 h-4 text-blue-600" />
                        <label className={`text-sm font-bold ${textPrim} whitespace-nowrap`}>過濾彈性時間:</label>
                        <select value={bufferHours} onChange={(e) => setBufferHours(Number(e.target.value))} className={`${selectCls} border rounded text-sm py-0.5 px-2 font-medium focus:outline-none focus:ring-2 focus:ring-blue-500`}>
                            <option value={0}>0 小時</option><option value={1}>1 小時 (預設)</option><option value={2}>2 小時</option>
                            <option value={3}>3 小時</option><option value={4}>4 小時</option><option value={6}>6 小時</option>
                        </select>
                    </div>
                </div>
                <div className="flex flex-wrap justify-end gap-2">
                    <FilterToggle active={hideObstacles} onClick={() => setHideObstacles(!hideObstacles)} icon={MountainSnow} label="障礙物/吊車" activeColorClass="bg-indigo-50 border-indigo-200 text-indigo-700" inactiveColorClass={`${innerCard} border text-slate-500`} dotColor="bg-indigo-500" />
                    <FilterToggle active={hideBirds}     onClick={() => setHideBirds(!hideBirds)}     icon={Bird}         label="鳥類/動物"   activeColorClass="bg-cyan-50 border-cyan-200 text-cyan-700"     inactiveColorClass={`${innerCard} border text-slate-500`} dotColor="bg-cyan-500" />
                    <FilterToggle active={hideUAS}       onClick={() => setHideUAS(!hideUAS)}         icon={SendKite}     label="氣球/無人機" activeColorClass="bg-violet-50 border-violet-200 text-violet-700" inactiveColorClass={`${innerCard} border text-slate-500`} dotColor="bg-violet-500" />
                    <FilterToggle active={hideMowing}    onClick={() => setHideMowing(!hideMowing)}   icon={Tractor}      label="除草/維護"   activeColorClass="bg-lime-50 border-lime-200 text-lime-700"     inactiveColorClass={`${innerCard} border text-slate-500`} dotColor="bg-lime-500" />
                </div>
            </div>
        );

        const formatNotamText = (text, isDimmed) => {
            const regex = /(\b(?:RWY|RUNWAY)\s+[0-3]?\d[LRC]?(?:\s*\/\s*[0-3]?\d[LRC]?)?\b|\b(?:TWY|TAXIWAY|TXL)\s+[A-Z0-9]+\b|\bILS(?:(?:\s+OR\s+LOC)?\s+(?:RWY|RUNWAY)?\s*[0-3]?\d[LRC]?)?\b)/gi;
            const parts = text.split(regex);
            return parts.map((part, idx) => {
                if (!part) return null;
                const up = part.toUpperCase();
                if (/^\b(?:RWY|RUNWAY)\b/.test(up)) {
                    return darkMode
                        ? <span key={idx} className={`font-black px-1 py-0.5 rounded-md shadow-sm border rwy-hl`}>{part}</span>
                        : <span key={idx} className={`font-black text-black px-1 py-0.5 rounded-md shadow-sm border ${isDimmed ? 'bg-yellow-100/50 border-yellow-200' : 'bg-yellow-200/70 border-yellow-300'}`}>{part}</span>;
                } else if (/^\b(?:TWY|TAXIWAY|TXL)\b/.test(up) || up.startsWith('ILS')) {
                    return <span key={idx} className={`font-black ils-hl ${isDimmed ? (darkMode ? 'text-[#8b949e]' : 'text-slate-600') : (darkMode ? 'text-[#e2e8f0]' : 'text-slate-900')}`}>{part}</span>;
                }
                return <Fragment key={idx}>{part}</Fragment>;
            });
        };

        const NotamCard = ({ notam, isSelected, onToggle }) => {
            let borderClass = darkMode ? 'border-[#30363d] bg-[#161b22]' : 'border-slate-200';
            let badge = null;
            const dm = darkMode;

            if (notam.keep || isSelected) {
                if (notam.category === 'RWY_CLSD')       { borderClass = dm ? 'border-l-4 border-l-rose-500 border-[#30363d] bg-rose-900/20'   : 'border-l-4 border-l-rose-500 border-y-rose-200 border-r-rose-200 bg-rose-50/30';   badge = <span className="ml-3 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-rose-100 text-rose-800 border border-rose-200">🚨 跑道關閉</span>; }
                else if (notam.category === 'TWY_CLSD')  { borderClass = dm ? 'border-l-4 border-l-amber-500 border-[#30363d] bg-amber-900/20'  : 'border-l-4 border-l-amber-500 border-y-amber-200 border-r-amber-200 bg-amber-50/30'; badge = <span className="ml-3 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800 border border-amber-200">🚧 滑行道/停機坪關閉</span>; }
                else if (notam.category === 'COMPANY_NOTAM') { borderClass = dm ? 'border-l-4 border-l-teal-500 border-[#30363d] bg-teal-900/20' : 'border-l-4 border-l-teal-500 border-y-teal-200 border-r-teal-200 bg-teal-50/30'; badge = <span className="ml-3 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-teal-100 text-teal-800 border border-teal-200"><Building className="w-3 h-3 mr-1"/> 公司通報</span>; }
