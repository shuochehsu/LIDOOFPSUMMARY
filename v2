    function ExportModal({ onClose, ofpData, depNotams, destNotams, selectedNotams, crosswindDep, crosswindDest, flightCatDep, flightCatDest }) {
        const [copied, setCopied] = useState(false);

        const buildText = () => {
            const line = (n=40) => '─'.repeat(n);
            const dbl  = (n=40) => '═'.repeat(n);
            let out = [];

            out.push(dbl(52));
            out.push(`  ✈  LIDO OFP 駕駛艙精華版`);
            if (ofpData) {
                out.push(`  ${ofpData.flightNo}  |  ${ofpData.route}  |  ${ofpData.date}`);
                if (ofpData.fleetInfo) out.push(`  機型: ${ofpData.reg} (${ofpData.fleetInfo})`);
            }
            out.push(dbl(52));
            out.push('');

            if (ofpData) {
