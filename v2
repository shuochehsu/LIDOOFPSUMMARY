const getAbsMinsFromZ = (hhmmZ, baseDate, stdMinsRaw) => {
    let hh = parseInt(hhmmZ.substring(0,2)); let mm = parseInt(hhmmZ.substring(2,4)); let day = baseDate;
    if (hh*60+mm < stdMinsRaw-360) day += 1;
    return day*24*60+hh*60+mm;
};

const parseOFP = (text) => {
    const data = { flightNo:'N/A', date:'N/A', route:'N/A', reg:'N/A', fleetInfo:'', depIcao:'N/A', arrIcao:'N/A', altnIcao:'N/A', stdL:'N/A', stdZ:'N/A', staL:'N/A', staZ:'N/A', altnEtaZ:'N/A', stdMins:null, staMins:null, altnEtaMins:null, flightTime:'N/A', blockTime:'N/A', zfwLimit:'N/A', zfwPlanned:'N/A', ldwLimit:'N/A', ldwPlanned:'N/A', towLimit:'N/A', towPlanned:'N/A', totalFuel:'N/A', reserveFuelSum:'N/A', ci:'N/A', fl:'N/A', tkofRwy:'N/A', sid:'N/A', ldgRwy:'N/A', star:'N/A', weather:[], validityWindows:{}, baseDate:1 };
    try {
        const topText = text.substring(0, 15000);
        const headerMatch = topText.match(/([A-Z0-9\s]+)\/(\d{2}[A-Za-z]{3}\d{2})\/([A-Z]{3,4}-[A-Z]{3,4})\s+Reg:\s*([A-Z0-9-]+)/i);
        if (headerMatch) {
            data.flightNo = headerMatch[1].replace(/\s+/g, ''); data.date = headerMatch[2].toUpperCase(); data.route = headerMatch[3]; data.reg = headerMatch[4];
            let regNum = data.reg.replace(/[^0-9]/g, '');
            const fleet77M = ['16703','16705','16706','16707','16708','16709','16710','16711','16712','16713','16715','16716','16717'];
            const fleet77A = ['16718','16719','16720','16721','16722','16723','16725','16726','16727','16728','16729'];
            const fleet77B = ['16730','16731','16732','16733','16735','16736','16737','16738','16739','16740'];
            const fleet77F = ['16781','16782','16783','16785','16786','16787','16788','16789','16790'];
            if (fleet77M.includes(regNum)) data.fleetInfo = '77M (323)'; else if (fleet77A.includes(regNum)) data.fleetInfo = '77A (333)'; else if (fleet77B.includes(regNum)) data.fleetInfo = '77B (353)'; else if (fleet77F.includes(regNum)) data.fleetInfo = '77F (Cargo)';
        }
        const depArrMatch = topText.match(/([A-Z]{4})\/([A-Z]{4})/); if (depArrMatch) { data.depIcao = depArrMatch[1]; data.arrIcao = depArrMatch[2]; }
        const dateMatch = topText.match(/(\d{2})[A-Za-z]{3}\d{2}/i); if (dateMatch) data.baseDate = parseInt(dateMatch[1]);
        let stdMinsRaw = 0; const stdMatch = topText.match(/STD\s+(\d{4}L)\s+(\d{4}Z)/); if (stdMatch) { data.stdL = stdMatch[1]; data.stdZ = stdMatch[2]; stdMinsRaw = parseInt(data.stdZ.substring(0,2))*60+parseInt(data.stdZ.substring(2,4)); data.stdMins = data.baseDate*24*60+stdMinsRaw; }
        const staMatch = topText.match(/STA\s+(\d{4}L)\s+(\d{4}[Zz27])/); if (staMatch) { data.staL = staMatch[1]; data.staZ = staMatch[2].replace(/[27]$/, 'Z'); if (data.stdMins !== null) data.staMins = getAbsMinsFromZ(data.staZ, data.baseDate, stdMinsRaw); }
