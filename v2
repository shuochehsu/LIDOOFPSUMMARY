            {showTopBtn && (
                <button onClick={() => window.scrollTo({top:0,behavior:'smooth'})} className={`fixed bottom-8 right-8 sm:bottom-12 sm:right-12 p-3 sm:px-5 sm:py-3.5 rounded-full shadow-[0_10px_25px_rgba(0,0,0,0.5)] hover:-translate-y-1 transition-all duration-300 z-[999] opacity-90 hover:opacity-100 flex items-center gap-2 ${darkMode?'bg-[#21262d] text-[#c9d1d9] hover:bg-[#30363d]':'bg-slate-800 text-white hover:bg-slate-700'}`} title="回到最上方">
                    <ChevronUp className="w-6 h-6"/>
                    <span className="hidden sm:inline font-bold tracking-wider">TOP</span>
                </button>
            )}
        </div>
    );
}

const root = ReactDOM.createRoot(document.getElementById('root'));
