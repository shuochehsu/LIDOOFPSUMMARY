function OfpSummaryApp({ rawText, darkMode, onOfpDataReady, onCrosswindReady }) {
    const [data, setData] = useState(null);
    const [useLiveWx, setUseLiveWx] = useState(false);
    const [liveWxData, setLiveWxData] = useState({});
    const [isFetchingWx, setIsFetchingWx] = useState(false);
    const [localError, setLocalError] = useState(null);

    useEffect(() => {
        if (!rawText) { setData(null); setLocalError(null); return; }
        try {
            const nd = parseOFP(rawText);
            if (nd.flightNo === 'N/A' || !nd.weather || nd.weather.length === 0) throw new Error("Missing OFP data");
            setData(nd);
            if (onOfpDataReady) onOfpDataReady(nd);
            setLocalError(null);
        } catch(err) {
            console.error("OFP parsing error:", err);
            setLocalError("無法解析 OFP 摘要結構，請確認檔案格式是否正確。");
        }
    }, [rawText]);

    // 計算側風並通知父層
    useEffect(() => {
        if (!data || !onCrosswindReady) return;
        // DEP crosswind from first METAR of depIcao
        const depWx = data.weather.find(w => w.icao === data.depIcao);
        const arrWx = data.weather.find(w => w.icao === data.arrIcao);

        const depWind  = depWx ? parseMetarWind(depWx.raw) : null;
        const arrWind  = arrWx ? parseMetarWind(arrWx.raw) : null;
        const depHdg   = rwyToHeading(data.tkofRwy);
        const arrHdg   = rwyToHeading(data.ldgRwy);

        const xwDep  = (depWind && !depWind.isVRB && depHdg !== null) ? calcCrosswind(depWind.dir, depWind.spd, depHdg) : null;
        const xwArr  = (arrWind && !arrWind.isVRB && arrHdg !== null) ? calcCrosswind(arrWind.dir, arrWind.spd, arrHdg) : null;

        const fcDep  = depWx ? getFlightCategory(depWx.raw) : null;
        const fcArr  = arrWx ? getFlightCategory(arrWx.raw) : null;

        onCrosswindReady({ xwDep, xwArr, fcDep, fcArr });
    }, [data]);

    const fetchRawViaProxy = async (url) => {
        const proxies = [`https://api.allorigins.win/raw?url=${encodeURIComponent(url)}`, `https://api.codetabs.com/v1/proxy?quest=${encodeURIComponent(url)}`];
        for (let p of proxies) {
            try {
                const ctrl = new AbortController();
                const id = setTimeout(() => ctrl.abort(), 4000);
                const res = await fetch(p, { signal: ctrl.signal, cache: 'no-store' });
                clearTimeout(id);
                if (res.ok) { const t = await res.text(); if (!t.includes('<html') && !t.includes('<body')) return t; }
            } catch(e) {}
        }
        return '';
    };

    const handleToggleLiveWx = async (mode) => {
        if (mode === useLiveWx) return;
        setUseLiveWx(mode);
        if (mode && Object.keys(liveWxData).length === 0 && data && data.weather) {
            setIsFetchingWx(true);
            const icaos = data.weather.map(w => w.icao); const newWx = { ...liveWxData };
            await Promise.all(icaos.map(async (icao) => {
                const cb = Date.now();
                const mT = await fetchRawViaProxy(`https://aviationweather.gov/api/data/metar?ids=${icao}&format=raw&cb=${cb}`);
                const tT = await fetchRawViaProxy(`https://aviationweather.gov/api/data/taf?ids=${icao}&format=raw&cb=${cb}`);
                let combined = '';
                if (mT && mT.trim()) combined += mT.trim() + '\n\n';
                if (tT && tT.trim()) combined += tT.trim();
                newWx[icao] = combined || '連線逾時 (4秒)，請切換回 OFP 原本查看。';
            }));
            setLiveWxData(newWx); setIsFetchingWx(false);
            // Re-calculate crosswind with live data
            if (onCrosswindReady && data) {
                const depIcao = data.depIcao; const arrIcao = data.arrIcao;
                const depWind  = parseMetarWind(newWx[depIcao] || '');
                const arrWind  = parseMetarWind(newWx[arrIcao] || '');
                const xwDep = (depWind && !depWind.isVRB) ? calcCrosswind(depWind.dir, depWind.spd, rwyToHeading(data.tkofRwy)) : null;
                const xwArr = (arrWind && !arrWind.isVRB) ? calcCrosswind(arrWind.dir, arrWind.spd, rwyToHeading(data.ldgRwy)) : null;
                const fcDep = getFlightCategory(newWx[depIcao] || '');
                const fcArr = getFlightCategory(newWx[arrIcao] || '');
                onCrosswindReady({ xwDep, xwArr, fcDep, fcArr });
            }
        }
    };

    if (localError) return (
        <div className="max-w-6xl mx-auto px-4 mt-8">
