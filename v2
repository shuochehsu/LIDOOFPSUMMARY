const highlightTAF = (wxText, windows, targetMins, targetType, baseDate) => {
    if (!wxText) return null;
    const normDay = d => { if(d<baseDate-15) return d+30; if(d>baseDate+15) return d-30; return d; };
    const lines = wxText.split('\n');
    const pLines = lines.map(line => {
        let start=-1,end=-1,isFm=false;
        const pM=line.match(/\b(\d{2})(\d{2})\/(\d{2})(\d{2})\b/); const fM=line.match(/FM(\d{2})(\d{2})(\d{2})/);
        if(pM){start=normDay(parseInt(pM[1]))*24*60+parseInt(pM[2])*60;end=normDay(parseInt(pM[3]))*24*60+parseInt(pM[4])*60;}
        else if(fM){start=normDay(parseInt(fM[1]))*24*60+parseInt(fM[2])*60+parseInt(fM[3]);isFm=true;}
        return {line,start,end,isFm,finalStart:-1,finalEnd:-1};
    });
    let mainStart=-1,mainEnd=-1;
    for(let pl of pLines){if(pl.line.trim().match(/^(FT|FC|TAF|TAF\s+K[A-Z]{3})\b/)&&!pl.isFm&&pl.start!==-1&&pl.end!==-1){mainStart=pl.start;mainEnd=pl.end;break;}}
    if(mainStart===-1){for(let pl of pLines){if(!pl.isFm&&pl.start!==-1&&pl.end!==-1){mainStart=pl.start;mainEnd=pl.end;break;}}}
    let curFmS=-1,inT=false; let hasM=wxText.match(/^(SA|SP|METAR|SPECI)\b/m); if(!hasM) inT=true;
    for(let i=0;i<pLines.length;i++){
        let pl=pLines[i],rL=pl.line.trim();
        if(rL.match(/^(FT|FC|TAF)\b/)) inT=true; else if(rL.match(/^(SA|SP|METAR|SPECI)\b/)) inT=false;
        if(!inT){pl.finalStart=-1;pl.finalEnd=-1;continue;}
        if(pl.isFm){curFmS=pl.start;let nFmS=mainEnd!==-1?mainEnd:curFmS+12*60;for(let j=i+1;j<pLines.length;j++){if(pLines[j].isFm){nFmS=pLines[j].start;break;}}pl.finalStart=curFmS;pl.finalEnd=nFmS;}
        else if(pl.start!==-1&&pl.end!==-1){pl.finalStart=pl.start;pl.finalEnd=pl.end;}
        else{if(curFmS!==-1){pl.finalStart=curFmS;let nFmS=mainEnd!==-1?mainEnd:curFmS+12*60;for(let j=i+1;j<pLines.length;j++){if(pLines[j].isFm){nFmS=pLines[j].start;break;}}pl.finalEnd=nFmS;}else{pl.finalStart=mainStart;pl.finalEnd=mainEnd;}}
    }
    return pLines.map((pl,idx) => {
        let hT=targetMins!==null&&pl.finalStart!==-1&&pl.finalEnd!==-1&&targetMins>=pl.finalStart&&targetMins<=pl.finalEnd;
        let hE=false; if(windows&&windows.length>0&&pl.finalStart!==-1&&pl.finalEnd!==-1){hE=windows.some(w=>Math.max(pl.finalStart,w.startMins)<Math.min(pl.finalEnd,w.endMins));}
        let hC='';
        if(hT&&hE) hC='bg-fuchsia-200 text-fuchsia-800 font-bold px-1 py-0.5 rounded shadow-sm';
        else if(hT){
            if(targetType==='DEP')  hC='bg-blue-200 text-blue-800 font-bold px-1 py-0.5 rounded shadow-sm';
            else if(targetType==='ARR')  hC='bg-emerald-200 text-emerald-800 font-bold px-1 py-0.5 rounded shadow-sm';
            else if(targetType==='ALTN') hC='bg-amber-200 text-amber-800 font-bold px-1 py-0.5 rounded shadow-sm';
            else hC='bg-indigo-200 text-indigo-800 font-bold px-1 py-0.5 rounded shadow-sm';
        } else if(hE) hC='bg-yellow-200 text-red-700 font-bold px-1 py-0.5 rounded shadow-sm';
        if(hC) return <Fragment key={idx}><span className={`inline-block ${hC}`}>{pl.line}</span>{'\n'}</Fragment>;
        return <Fragment key={idx}>{pl.line}{'\n'}</Fragment>;
    });
